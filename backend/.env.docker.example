# 复制成 backend/.env 给 docker-compose 用

SECRET_KEY=换成强随机串（python -c "import secrets; print(secrets.token_urlsafe(48))"）

OPENAI_API_KEY=你的key
MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 数据库放到持久卷里（容器内 /app/storage 挂了卷）
DATABASE_URL=sqlite:////app/storage/game_platform.db

# 允许本机前端
CORS_ORIGINS=http://localhost:3000

COVER_TIMEOUT_SECONDS=10
